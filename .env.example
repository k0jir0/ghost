# Ghost - AI Model Context & Training Platform
# Copy this file to .env and fill in your values.
# .env is gitignored - never commit secrets.

# ---------------------------------------------------------------------------
# Ollama (local LLM)
# ---------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=60

# ---------------------------------------------------------------------------
# ML Training Backend
# Options: pytorch | tensorflow | auto
# "auto" will use PyTorch if available, falling back to TensorFlow.
# ---------------------------------------------------------------------------
TRAINING_BACKEND=auto
GPU_ENABLED=true
CUDA_VISIBLE_DEVICES=0

# ---------------------------------------------------------------------------
# File paths
# ---------------------------------------------------------------------------
MODEL_CACHE_DIR=./models
DATA_CACHE_DIR=./data

# ---------------------------------------------------------------------------
# Logging
# Options: DEBUG | INFO | WARNING | ERROR
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=ghost.log

# ---------------------------------------------------------------------------
# Training defaults
# ---------------------------------------------------------------------------
DEFAULT_BATCH_SIZE=32
DEFAULT_LEARNING_RATE=0.001
DEFAULT_EPOCHS=10
CHECKPOINT_INTERVAL=5

# ---------------------------------------------------------------------------
# Training agent
# ---------------------------------------------------------------------------
# AI backend for agent assistance
# Options: ollama
AI_BACKEND=ollama

# Stop the agent and request human check-in after this many iterations.
MAX_ITERATIONS=100

# Enable only for scaffolding and demos when you intentionally want random
# batches instead of wiring a real dataset pipeline.
ALLOW_SYNTHETIC_DATA=false

# ---------------------------------------------------------------------------
# Health monitoring
# ---------------------------------------------------------------------------
# Cache health samples for this many seconds before taking a fresh reading.
HEALTH_CHECK_INTERVAL=30

# Fraction of GPU/system memory that triggers a warning (0.0 – 1.0).
GPU_MEMORY_THRESHOLD=0.9
SYSTEM_MEMORY_THRESHOLD=0.85
